{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/JobApplicationAssistant.API/JobApplicationAssistant.API.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "ASPNETCORE_URLS=http://0.0.0.0:$PORT ./out/JobApplicationAssistant.API",
    "restartPolicyType": "ON_FAILURE"
  }
}